{
    "name": "marcinzmuda/ligase",
    "description": "Schema.org JSON-LD markup for WordPress blogs, optimized for Google Rich Results and AI Search.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Marcin Zmuda",
            "homepage": "https://marcinzmuda.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "admin/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:coverage": "./vendor/bin/phpunit --coverage-html=coverage"
    }
}
