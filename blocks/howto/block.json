{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ligase/howto",
  "title": "HowTo Schema",
  "description": "Dodaj kroki instrukcji z automatycznym generowaniem HowTo schema.org",
  "category": "text",
  "icon": "editor-ol",
  "textdomain": "ligase",
  "attributes": {
    "name": { "type": "string", "default": "" },
    "totalTime": { "type": "string", "default": "" },
    "steps": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "default": "" },
          "text": { "type": "string", "default": "" }
        }
      }
    }
  },
  "editorScript": "file:./index.js"
}
